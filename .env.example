# ============================================
# AI Flow Builder — Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Master Password for Credential Vault (CHANGE THIS!)
MASTER_PASSWORD=your-super-secret-master-password-change-me

# Google Vertex AI (Gemini)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Browser Configuration
CHROME_EXECUTABLE_PATH=
HEADLESS=true
DEFAULT_VIEWPORT_WIDTH=1366
DEFAULT_VIEWPORT_HEIGHT=768

# Proxy (Optional - recommended for Google automation)
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Session
SESSION_SECRET=your-session-secret-change-me
